    {
      "Name": "Network Latency Optimization",
      "Function": "NaglesAlgorithm",
      "Type": "Toggle",
      "Options": null,
      "DisplayOptions": null,
      "Default": false,
      "WinDefault": true,
      "Description": "Reduces network buffering for lower latency. May affect connection stability.",
      "Detail": "Disables TCP send coalescing (Nagle's Algorithm) so packets are sent immediately instead of being batched. Can lower network latency in competitive multiplayer games at the cost of slightly more network traffic. Affects all TCP connections, not just games. If you experience connection drops or instability after enabling, disable this tweak.",
      "Caution": true,
      "CautionReason": "Applies per-adapter registry values to all active physical network adapters. Affects all TCP traffic, not just games. May cause connection instability on some networks. Safe to undo.",
      "LinkedWith": null,
      "Scannable": null,
      "Restorable": true,
      "OnParam": "Enable",
      "OffParam": "Disable",
      "ExtraArgs": null,
      "SubCategory": null,
      "SourceRegion": "Gaming",
      "WinDefaultDesc": "TCP send coalescing is active (Nagle's Algorithm enabled)",
      "Risk": "Medium",
      "Tags": [
